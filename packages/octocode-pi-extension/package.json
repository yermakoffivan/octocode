{
  "name": "@octocodeai/pi-extension",
  "version": "1.0.2",
  "description": "Official Octocode Pi package: system prompt, skills, harness docs, and setup commands for coding agents.",
  "keywords": [
    "ai-coding",
    "coding-agent",
    "octocode",
    "pi",
    "pi-package",
    "skills"
  ],
  "author": "Guy Bary <bgauryy@octocodeai.com>",
  "homepage": "https://octocode.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bgauryy/octocode-mcp.git",
    "directory": "packages/octocode-pi-extension"
  },
  "bugs": "https://github.com/bgauryy/octocode-mcp/issues",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**",
    "skills/**",
    "docs/**",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@octocodeai/octocode-awareness": "workspace:*",
    "@octocodeai/octocode-core": "^16.6.3",
    "@octocodeai/octocode-tools-core": "workspace:*"
  },
  "devDependencies": {
    "@octocodeai/config": "workspace:*",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "typebox": {
      "optional": true
    }
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:skills": "node scripts/build.mjs --skills-only",
    "clean": "node scripts/build.mjs --clean",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "yarn build && node ../../node_modules/vitest/vitest.mjs run",
    "test:unit": "node ../../node_modules/vitest/vitest.mjs run",
    "test:watch": "node ../../node_modules/vitest/vitest.mjs --watch",
    "test:coverage": "node ../../node_modules/vitest/vitest.mjs run --coverage",
    "verify": "yarn typecheck && yarn test",
    "check:no-workspace": "node scripts/check-no-workspace-protocol.mjs",
    "prepack": "node scripts/check-no-workspace-protocol.mjs && yarn build",
    "prepublishOnly": "node scripts/check-no-workspace-protocol.mjs",
    "readme:sync": "node ../../scripts/sync-package-readmes.mjs ."
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ],
    "skills": [
      "./dist/skills"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "octocode": {
    "readmeSync": false
  }
}
