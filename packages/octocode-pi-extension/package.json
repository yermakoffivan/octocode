{
  "name": "@octocodeai/pi-extension",
  "version": "1.0.2",
  "description": "Official Octocode Pi package: system prompt, skills, harness docs, and setup commands for coding agents.",
  "keywords": [
    "ai-coding",
    "coding-agent",
    "octocode",
    "pi",
    "pi-package",
    "skills"
  ],
  "author": "Guy Bary <bgauryy@octocodeai.com>",
  "homepage": "https://octocode.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bgauryy/octocode-mcp.git",
    "directory": "packages/octocode-pi-extension"
  },
  "bugs": "https://github.com/bgauryy/octocode-mcp/issues",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/**",
    "skills/**",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "octocode": "workspace:*",
    "@octocodeai/octocode-core": ">=16.6.1"
  },
  "devDependencies": {
    "@octocodeai/config": "workspace:*"
  },
  "peerDependencies": {
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "typebox": {
      "optional": true
    }
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "clean": "node scripts/build.mjs --clean",
    "lint": "node --check src/index.js && node --check scripts/build.mjs && node --check tests/package.test.mjs",
    "test": "yarn build && node --test tests/*.test.mjs",
    "typecheck": "yarn lint",
    "verify": "yarn lint && yarn test && yarn build",
    "check:no-workspace": "node scripts/check-no-workspace-protocol.mjs",
    "prepack": "node scripts/check-no-workspace-protocol.mjs && yarn build",
    "prepublishOnly": "node scripts/check-no-workspace-protocol.mjs",
    "readme:sync": "node ../../scripts/sync-package-readmes.mjs ."
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ],
    "skills": [
      "./skills",
      "./dist/skills"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "octocode": {
    "readmeSync": false
  }
}
