{
  "name": "@octocodeai/octocode-engine",
  "description": "Rust native Octocode engine for context compression, structural search, and LSP semantic navigation",
  "version": "17.0.2",
  "author": "Guy Bary <bgauryy@octocodeai.com>",
  "dependencies": {
    "@octocodeai/config": "^17.0.2",
    "bash-language-server": "^5.6.0",
    "intelephense": "^1.14.1",
    "pyright": "^1.1.411",
    "typescript": "^5.9.3",
    "typescript-language-server": "^4.4.0",
    "vscode-langservers-extracted": "^4.10.0",
    "yaml-language-server": "^1.23.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.2",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.cjs",
      "default": "./index.js"
    },
    "./security": {
      "types": "./dist/security/index.d.ts",
