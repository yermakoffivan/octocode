    },
    "./lsp/evidence": {
      "types": "./dist/lsp/evidence.d.ts",
      "import": "./dist/lsp/evidence.js",
      "default": "./dist/lsp/evidence.js"
    },
    "./lsp/initConstants": {
      "types": "./dist/lsp/initConstants.d.ts",
      "import": "./dist/lsp/initConstants.js",
      "default": "./dist/lsp/initConstants.js"
    },
    "./lsp/lspClientPool": {
      "types": "./dist/lsp/lspClientPool.d.ts",
      "import": "./dist/lsp/lspClientPool.js",
      "default": "./dist/lsp/lspClientPool.js"
    },
    "./lsp/lspErrorCodes": {
      "types": "./dist/lsp/lspErrorCodes.d.ts",
      "import": "./dist/lsp/lspErrorCodes.js",
      "default": "./dist/lsp/lspErrorCodes.js"
    },
    "./lsp/manager": {
      "types": "./dist/lsp/manager.d.ts",
      "import": "./dist/lsp/manager.js",
      "default": "./dist/lsp/manager.js"
    },
    "./lsp/platform": {
      "types": "./dist/lsp/platform.d.ts",
      "import": "./dist/lsp/platform.js",
      "default": "./dist/lsp/platform.js"
    },
    "./lsp/serverDiscovery": {
      "types": "./dist/lsp/serverDiscovery.d.ts",
      "import": "./dist/lsp/serverDiscovery.js",
      "default": "./dist/lsp/serverDiscovery.js"
    },
    "./lsp/serverManifest": {
      "types": "./dist/lsp/serverManifest.d.ts",
      "import": "./dist/lsp/serverManifest.js",
      "default": "./dist/lsp/serverManifest.js"
    },
    "./lsp/serverProvisioner": {
      "types": "./dist/lsp/serverProvisioner.d.ts",
      "import": "./dist/lsp/serverProvisioner.js",
      "default": "./dist/lsp/serverProvisioner.js"
    },
    "./lsp/resolver": {
      "types": "./dist/lsp/resolver.d.ts",
