{
  "name": "octocode-agent",
  "version": "1.0.2",
  "description": "Self-working coding agent platform: launches Pi with the Octocode harness (@octocodeai/pi-extension) as its core — one branded command, one update path.",
  "keywords": [
    "ai-coding",
    "coding-agent",
    "octocode",
    "pi",
    "agent",
    "cli"
  ],
  "author": "Guy Bary <bgauryy@octocodeai.com>",
  "homepage": "https://octocode.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bgauryy/octocode-mcp.git",
    "directory": "packages/octocode-agent"
  },
  "bugs": "https://github.com/bgauryy/octocode-mcp/issues",
  "license": "MIT",
  "type": "module",
  "bin": "./bin/octocode-agent.mjs",
  "exports": {
    "./launcher": "./bin/launcher.mjs"
  },
  "files": [
    "bin/**",
    "docs/**",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.80.3",
    "@octocodeai/pi-extension": "workspace:*"
  },
  "scripts": {
    "build": "yarn lint",
    "start": "node ./bin/octocode-agent.mjs",
    "lint": "node --check bin/octocode-agent.mjs && node --check bin/launcher.mjs && node --check tests/launcher.test.mjs",
    "test": "node --test tests/*.test.mjs",
    "typecheck": "yarn lint",
    "verify": "yarn lint && yarn test",
    "check:no-workspace": "node scripts/check-no-workspace-protocol.mjs",
    "prepack": "node scripts/check-no-workspace-protocol.mjs",
    "prepublishOnly": "node scripts/check-no-workspace-protocol.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "octocode": {
    "readmeSync": false
  }
}
