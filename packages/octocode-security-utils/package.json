{
  "name": "octocode-security-utils",
  "version": "1.0.0",
  "description": "Security module for Octocode — path validation, sanitization, masking, sensitive-data detection",
  "author": "Guy Bary <bgauryy@octocodeai.com>",
  "homepage": "https://octocode.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bgauryy/octocode-mcp.git",
    "directory": "packages/octocode-security-utils"
  },
  "bugs": "https://github.com/bgauryy/octocode-mcp/issues",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pathValidator": {
      "types": "./dist/pathValidator.d.ts",
      "import": "./dist/pathValidator.js"
    },
    "./commandValidator": {
      "types": "./dist/commandValidator.d.ts",
      "import": "./dist/commandValidator.js"
    },
    "./contentSanitizer": {
      "types": "./dist/contentSanitizer.d.ts",
      "import": "./dist/contentSanitizer.js"
    },
    "./withSecurityValidation": {
      "types": "./dist/withSecurityValidation.d.ts",
      "import": "./dist/withSecurityValidation.js"
    },
    "./mask": {
      "types": "./dist/mask.d.ts",
      "import": "./dist/mask.js"
    },
    "./ignoredPathFilter": {
      "types": "./dist/ignoredPathFilter.d.ts",
      "import": "./dist/ignoredPathFilter.js"
    },
    "./workspaceRoot": {
      "types": "./dist/workspaceRoot.d.ts",
      "import": "./dist/workspaceRoot.js"
    },
    "./executionContextValidator": {
      "types": "./dist/executionContextValidator.d.ts",
      "import": "./dist/executionContextValidator.js"
    },
    "./pathUtils": {
      "types": "./dist/pathUtils.d.ts",
      "import": "./dist/pathUtils.js"
    },
    "./regexes": {
      "types": "./dist/regexes/index.d.ts",
      "import": "./dist/regexes/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./paramExtractors": {
      "types": "./dist/paramExtractors.d.ts",
      "import": "./dist/paramExtractors.js"
    },
    "./registry": {
      "types": "./dist/registry.d.ts",
      "import": "./dist/registry.js"
    }
  },
  "typesVersions": {
    "*": {
      "pathValidator": [
        "./dist/pathValidator.d.ts"
      ],
      "commandValidator": [
        "./dist/commandValidator.d.ts"
      ],
      "contentSanitizer": [
        "./dist/contentSanitizer.d.ts"
      ],
      "withSecurityValidation": [
        "./dist/withSecurityValidation.d.ts"
      ],
      "mask": [
        "./dist/mask.d.ts"
      ],
      "ignoredPathFilter": [
        "./dist/ignoredPathFilter.d.ts"
      ],
      "workspaceRoot": [
        "./dist/workspaceRoot.d.ts"
      ],
      "executionContextValidator": [
        "./dist/executionContextValidator.d.ts"
      ],
      "pathUtils": [
        "./dist/pathUtils.d.ts"
      ],
      "regexes": [
        "./dist/regexes/index.d.ts"
      ],
      "types": [
        "./dist/types.d.ts"
      ],
      "paramExtractors": [
        "./dist/paramExtractors.d.ts"
      ],
      "registry": [
        "./dist/registry.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "yarn lint && node build.mjs && tsc --emitDeclarationOnly",
    "build:dev": "node build.mjs && tsc --emitDeclarationOnly",
    "clean": "rm -rf dist/",
    "lint": "eslint src tests",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "verify": "yarn lint && yarn typecheck && yarn test"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@vitest/coverage-v8": "^4.0.16",
    "esbuild": "^0.27.2",
    "eslint": "^9.18.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
