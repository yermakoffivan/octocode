{
  "name": "octocode-lsp",
  "version": "16.3.0",
  "description": "Reusable LSP client, server registry, and semantic navigation runtime for Octocode",
  "keywords": [
    "code-intelligence",
    "language-server",
    "lsp",
    "octocode",
    "typescript"
  ],
  "author": "Guy Bary <bgauryy@octocodeai.com>",
  "homepage": "https://octocode.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bgauryy/octocode-mcp.git",
    "directory": "packages/octocode-lsp"
  },
  "bugs": "https://github.com/bgauryy/octocode-mcp/issues",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "default": "./dist/config.js"
    },
    "./evidence": {
      "types": "./dist/evidence.d.ts",
      "import": "./dist/evidence.js",
      "default": "./dist/evidence.js"
    },
    "./initConstants": {
      "types": "./dist/initConstants.d.ts",
      "import": "./dist/initConstants.js",
      "default": "./dist/initConstants.js"
    },
    "./lspClientPool": {
      "types": "./dist/lspClientPool.d.ts",
      "import": "./dist/lspClientPool.js",
      "default": "./dist/lspClientPool.js"
    },
    "./lspErrorCodes": {
      "types": "./dist/lspErrorCodes.d.ts",
      "import": "./dist/lspErrorCodes.js",
      "default": "./dist/lspErrorCodes.js"
    },
    "./manager": {
      "types": "./dist/manager.d.ts",
      "import": "./dist/manager.js",
      "default": "./dist/manager.js"
    },
    "./resolver": {
      "types": "./dist/resolver.d.ts",
      "import": "./dist/resolver.js",
      "default": "./dist/resolver.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "import": "./dist/schemas.js",
      "default": "./dist/schemas.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./uri": {
      "types": "./dist/uri.d.ts",
      "import": "./dist/uri.js",
      "default": "./dist/uri.js"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "import": "./dist/validation.js",
      "default": "./dist/validation.js"
    },
    "./workspaceRoot": {
      "types": "./dist/workspaceRoot.d.ts",
      "import": "./dist/workspaceRoot.js",
      "default": "./dist/workspaceRoot.js"
    }
  },
  "typesVersions": {
    "*": {
      "client": [
        "./dist/client.d.ts"
      ],
      "config": [
        "./dist/config.d.ts"
      ],
      "evidence": [
        "./dist/evidence.d.ts"
      ],
      "initConstants": [
        "./dist/initConstants.d.ts"
      ],
      "lspClientPool": [
        "./dist/lspClientPool.d.ts"
      ],
      "lspErrorCodes": [
        "./dist/lspErrorCodes.d.ts"
      ],
      "manager": [
        "./dist/manager.d.ts"
      ],
      "resolver": [
        "./dist/resolver.d.ts"
      ],
      "schemas": [
        "./dist/schemas.d.ts"
      ],
      "types": [
        "./dist/types.d.ts"
      ],
      "uri": [
        "./dist/uri.d.ts"
      ],
      "validation": [
        "./dist/validation.d.ts"
      ],
      "workspaceRoot": [
        "./dist/workspaceRoot.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "optionalDependencies": {
    "octocode-lsp-darwin-arm64": "16.3.0",
    "octocode-lsp-darwin-x64": "16.3.0",
    "octocode-lsp-linux-arm64-gnu": "16.3.0",
    "octocode-lsp-linux-x64-gnu": "16.3.0",
    "octocode-lsp-linux-x64-musl": "16.3.0",
    "octocode-lsp-win32-x64-msvc": "16.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "rm -rf dist && napi build --platform --no-js --dts target/napi-rs/native.d.ts --release && node scripts/sync-platform-binaries.cjs && tsc -p tsconfig.build.json",
    "build:dev": "rm -rf dist && napi build --platform --no-js --dts target/napi-rs/native.d.ts && node scripts/sync-platform-binaries.cjs && tsc -p tsconfig.build.json",
    "build:native": "napi build --platform --no-js --dts target/napi-rs/native.d.ts --release && node scripts/sync-platform-binaries.cjs",
    "build:darwin-arm64": "napi build --platform --no-js --dts target/napi-rs/native.d.ts --release --target aarch64-apple-darwin && node scripts/sync-platform-binaries.cjs",
    "build:darwin-x64": "napi build --platform --no-js --dts target/napi-rs/native.d.ts --release --target x86_64-apple-darwin && node scripts/sync-platform-binaries.cjs",
    "build:linux-x64-gnu": "napi build --platform --no-js --dts target/napi-rs/native.d.ts --release --cross-compile --target x86_64-unknown-linux-gnu && node scripts/sync-platform-binaries.cjs",
    "build:linux-x64-musl": "napi build --platform --no-js --dts target/napi-rs/native.d.ts --release --cross-compile --target x86_64-unknown-linux-musl && node scripts/sync-platform-binaries.cjs",
    "build:linux-arm64-gnu": "napi build --platform --no-js --dts target/napi-rs/native.d.ts --release --cross-compile --target aarch64-unknown-linux-gnu && node scripts/sync-platform-binaries.cjs",
    "build:windows-x64": "napi build --platform --no-js --dts target/napi-rs/native.d.ts --release --cross-compile --target x86_64-pc-windows-msvc && node scripts/sync-platform-binaries.cjs",
    "build:ts": "rm -rf dist && tsc -p tsconfig.build.json",
    "build:all": "yarn build:darwin-arm64 && yarn build:darwin-x64 && yarn build:linux-x64-gnu && yarn build:linux-x64-musl && yarn build:linux-arm64-gnu && yarn build:windows-x64 && yarn build:ts",
    "pack:check": "node scripts/check-pack-size.cjs",
    "platforms:check": "node scripts/check-platform-binaries.cjs",
    "clean": "rm -rf dist/ *.node",
    "benchmark": "node benchmark/run.mjs",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "lint:rust": "cargo clippy --all-targets -- -D warnings",
    "test": "vitest run --coverage",
    "test:quiet": "vitest run --reporter=dot --silent",
    "test:watch": "vitest --watch",
    "test:rust": "cargo test",
    "typecheck": "tsc --noEmit",
    "verify": "yarn typecheck && yarn lint:rust && yarn test:rust && yarn lint && yarn test"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.1",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^9.18.0",
    "typescript": "^5.9.3",
    "typescript-language-server": "^5.3.0",
    "vitest": "^4.0.16"
  },
  "napi": {
    "binaryName": "octocode-lsp",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  }
}
