{
  "name": "@octocodeai/octocode-awareness",
  "version": "1.0.0",
  "description": "Octocode Awareness: always-on workspace coordination — awareness, collaboration, learning, memory/wiki, bookkeeping, housekeeping, reflection — zero npm runtime deps.",
  "keywords": [
    "octocode",
    "awareness",
    "collaboration",
    "memory",
    "bookkeeping",
    "housekeeping",
    "sqlite",
    "agent"
  ],
  "author": "Guy Bary <bgauryy@octocodeai.com>",
  "homepage": "https://octocode.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bgauryy/octocode-mcp.git",
    "directory": "packages/octocode-awareness"
  },
  "bugs": "https://github.com/bgauryy/octocode-mcp/issues",
  "license": "MIT",
  "type": "module",
  "main": "./out/index.js",
  "types": "./out/types/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./out/types/src/index.d.ts",
      "import": "./out/index.js",
      "default": "./out/index.js"
    },
    "./bin/awareness": "./out/octocode-awareness.js",
    "./bin/octocode-awareness": "./out/octocode-awareness.js",
    "./bin/extract-hook-files": "./out/extract-hook-files.js",
    "./schema": "./out/schema-api.js"
  },
  "bin": "./out/octocode-awareness.js",
  "files": [
    "out/**",
    "!docs/**",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "node build.mjs",
    "build:dev": "node build.mjs",
    "clean": "rm -rf out/ dist/",
    "lint": "node ../../node_modules/eslint/bin/eslint.js . --config eslint.config.mjs --no-warn-ignored && tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "yarn build && node ../../node_modules/vitest/vitest.mjs run --coverage",
    "test:quiet": "yarn build && node ../../node_modules/vitest/vitest.mjs run --reporter=dot --silent",
    "test:smoke": "node ../../skills/octocode-awareness/scripts/smoke-multi-agent.mjs",
    "pack:check": "node scripts/verify-package.mjs",
    "prepack": "yarn build && node scripts/verify-package.mjs",
    "self-test": "node out/octocode-awareness.js maintenance self-test",
    "start": "node out/octocode-awareness.js",
    "verify": "yarn lint && yarn test"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
