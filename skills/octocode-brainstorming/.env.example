# Environment variables for octocode-brainstorming
#
# Copy this file to .env in the same directory and fill in real values:
#   cp .env.example .env
#
# Do NOT commit .env — it is gitignored.
# The skill detects engine availability by running:
#   node scripts/serper-search.mjs --check
#   node scripts/tavily-search.mjs --check
# At least one key enables web research; both is fine.

# Serper API key — Google SERP results, fast and broad.
# Get a key at https://serper.dev/
SERPER_API_KEY=REPLACE_ME

# Tavily API key — AI-curated answers, deep research mode.
# Get a key at https://app.tavily.com/
TAVILY_API_KEY=tvly-REPLACE_ME
